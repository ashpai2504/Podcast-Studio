# Copy to .env.local for local development (next dev reads this automatically).
# In production on Vercel, set these under Project Settings -> Environment Variables
# instead - this file is never read there.

AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-5-mini
AZURE_OPENAI_API_VERSION=2025-04-01-preview

# Blank = reuse the API key above (multi-service resource)
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus
