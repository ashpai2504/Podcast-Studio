# Copy this file to .env and fill in your values.

# --- Azure OpenAI (script generation) ---
# From your Azure AI Foundry / AI Services resource: Keys and Endpoint page.
# Endpoint looks like https://<your-resource>.cognitiveservices.azure.com/
# or https://<your-resource>.openai.azure.com/
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
# The deployment NAME you gave the model when deploying it in Foundry (e.g. gpt-5-mini)
AZURE_OPENAI_DEPLOYMENT=gpt-5-mini
AZURE_OPENAI_API_VERSION=2025-04-01-preview

# --- Azure Speech (podcast audio) ---
# For a multi-service AI Services / Foundry resource this is the SAME key as above,
# and the region is where that resource lives (e.g. eastus).
# NOTE: DragonHD multi-talker voices are only served from a few regions
# (eastus, westeurope, southeastasia) - the resource must be in one of them.
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus
